# ─── App ───────────────────────────────────────────────────────────────────────
APP_NAME=BNR-Portal
APP_ENV=development                  # development | staging | production
DEBUG=true
FRONTEND_URL=http://localhost:3000

# ─── Database ──────────────────────────────────────────────────────────────────
# Use postgresql+psycopg for synchronous connection (SQLAlchemy)
DATABASE_URL=postgresql+psycopg://postgres:password@localhost:5432/bnr-portal

# ─── Security & JWT ────────────────────────────────────────────────────────────
SECRET_KEY=generate-a-long-random-hex-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── Email (Resend) ────────────────────────────────────────────────────────────
RESEND_API_KEY=re_your_api_key_here
FROM_EMAIL=onboarding@resend.dev

# ─── Timezone ──────────────────────────────────────────────────────────────────
TIMEZONE=Africa/Kigali

# ─── Optional Services (Placeholders) ──────────────────────────────────────────
# REDIS_URL=redis://localhost:6379/0
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=af-south-1
# AWS_S3_BUCKET=bnr-portal-media
